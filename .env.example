# Set these in Vercel Project Settings > Environment Variables.
# Never commit the real values.
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# Production only. Use a fine-grained token limited to this repository with
# Repository permissions > Contents: Read and write.
GITHUB_CONTENT_TOKEN=replace-with-a-fine-grained-github-token
GITHUB_REPOSITORY=letsgogreen/legitbodyfix
GITHUB_BRANCH=main
